rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER: get caller role safely ───────────────────────────────────────
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user');
    }

    function signedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return signedIn() && role() == 'super_admin';
    }

    function isAdminPlus() {
      return signedIn() && role() in ['super_admin', 'it_admin'];
    }

    function isAgentPlus() {
      return signedIn() && role() in ['super_admin', 'it_admin', 'it_agent'];
    }

    function isManagerPlus() {
      return signedIn() && role() in ['super_admin', 'it_admin', 'manager'];
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // ── USERS ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone signed in can READ their own profile
      allow read: if isOwner(userId) || isAdminPlus() || isManagerPlus();

      // Allow creating own profile on first login (bootstrapping)
      allow create: if isOwner(userId);

      // User can update own profile EXCEPT role field
      // Admins can update anything including role
      allow update: if
        (isOwner(userId) &&
          !('role' in request.resource.data.diff(resource.data).affectedKeys()))
        || isAdminPlus();

      allow delete: if isSuperAdmin();
    }

    // ── META (used for first-user detection) ─────────────────────────────────
    match /meta/{doc} {
      allow read:  if signedIn();
      allow write: if signedIn();  // Needed for first-login bootstrap
    }

    // ── TICKETS ──────────────────────────────────────────────────────────────
    match /tickets/{ticketId} {
      // Agents/admins/managers see all tickets
      // Users see only their own
      allow read: if isAgentPlus()
                  || isManagerPlus()
                  || (signedIn() && resource.data.requesterId == request.auth.uid);

      // Any signed-in user can create a ticket (as themselves)
      allow create: if signedIn()
                    && request.resource.data.requesterId == request.auth.uid;

      // Agents/admins can update any field
      // Users can only add comments to their own tickets
      allow update: if isAgentPlus()
                    || (signedIn()
                        && resource.data.requesterId == request.auth.uid
                        && request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasOnly(['comments', 'updatedAt']));

      allow delete: if isAdminPlus();
    }

    // ── KNOWLEDGE BASE ───────────────────────────────────────────────────────
    match /knowledge/{articleId} {
      allow read:  if signedIn();
      allow write: if isAgentPlus();
    }

    // ── SLA POLICIES ─────────────────────────────────────────────────────────
    match /sla_policies/{policyId} {
      allow read:  if signedIn();
      allow write: if isAdminPlus();
    }

    // ── NOTIFICATIONS ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:   if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAgentPlus();
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // ── AUDIT LOGS (immutable) ────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read:             if isAdminPlus();
      allow create:           if signedIn();
      allow update, delete:   if false;
    }

    // ── WORKFLOWS (Phase 2) ──────────────────────────────────────────────────
    match /workflows/{wfId} {
      allow read:  if isAgentPlus();
      allow write: if isAdminPlus();
    }

    // ── ASSETS (Phase 2 ITAM) ────────────────────────────────────────────────
    match /assets/{assetId} {
      allow read:  if isAgentPlus() || isManagerPlus();
      allow write: if isAdminPlus();
    }

    // ── ACCESS REQUESTS (Phase 2 IAM) ────────────────────────────────────────
    match /access_requests/{reqId} {
      allow read: if isAdminPlus()
                  || isManagerPlus()
                  || (signedIn() && resource.data.requesterId == request.auth.uid);
      allow create: if signedIn();
      allow update: if isAdminPlus() || isManagerPlus();
      allow delete: if isAdminPlus();
    }

    // ── CATALOG ITEMS ────────────────────────────────────────────────────────
    match /catalog/{itemId} {
      allow read:  if signedIn();
      allow write: if isAdminPlus();
    }
  }
}
