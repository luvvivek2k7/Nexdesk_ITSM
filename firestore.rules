rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuth()       { return request.auth != null; }
    function uid()          { return request.auth.uid; }
    function userDoc()      { return get(/databases/$(database)/documents/users/$(uid())); }
    function role()         { return userDoc().data.role; }
    function isSuperAdmin() { return role() == 'super_admin'; }
    function isAdmin()      { return role() in ['super_admin', 'it_admin']; }
    function isAgent()      { return role() in ['super_admin', 'it_admin', 'it_agent', 'manager']; }
    function isHR()         { return role() in ['super_admin', 'it_admin', 'hr', 'manager']; }
    function isFSO()        { return role() in ['super_admin', 'it_admin', 'field_engineer', 'manager']; }
    function isOwner(userId){ return uid() == userId; }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuth();
      allow create: if isAuth() && isAdmin();
      allow update: if isAuth() && (isAdmin() || isOwner(userId));
      allow delete: if isAuth() && isSuperAdmin();
    }

    // ── Tickets (ITSM) ────────────────────────────────────────────────────────
    match /tickets/{ticketId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && isAgent();
      allow delete: if isAuth() && isSuperAdmin();
    }

    // ── Ticket Comments ───────────────────────────────────────────────────────
    match /tickets/{ticketId}/comments/{commentId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && isOwner(resource.data.authorId);
      allow delete: if isAuth() && isAdmin();
    }

    // ── Assets (ITAM) ─────────────────────────────────────────────────────────
    match /assets/{assetId} {
      allow read:   if isAuth();
      allow create: if isAuth() && isAgent();
      allow update: if isAuth() && isAgent();
      allow delete: if isAuth() && isAdmin();
    }

    // ── Access Requests (IAM) ─────────────────────────────────────────────────
    match /accessRequests/{reqId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && isAgent();
      allow delete: if isAuth() && isAdmin();
    }

    // ── Work Orders (FSO) ─────────────────────────────────────────────────────
    match /workOrders/{woId} {
      allow read:   if isAuth();
      allow create: if isAuth() && isFSO();
      allow update: if isAuth() && isFSO();
      allow delete: if isAuth() && isAdmin();
    }

    // ── Visitors ──────────────────────────────────────────────────────────────
    match /visitors/{visId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && isAgent();
      allow delete: if isAuth() && isAdmin();
    }

    // ── Employees (HRMS) ──────────────────────────────────────────────────────
    match /employees/{empId} {
      allow read:   if isAuth();
      allow create: if isAuth() && isHR();
      allow update: if isAuth() && isHR();
      allow delete: if isAuth() && isAdmin();
    }

    // ── Assignment Groups ─────────────────────────────────────────────────────
    match /groups/{grpId} {
      allow read:   if isAuth();
      allow create: if isAuth() && isAdmin();
      allow update: if isAuth() && isAdmin();
      allow delete: if isAuth() && isSuperAdmin();
    }

    // ── Workflows ─────────────────────────────────────────────────────────────
    match /workflows/{wfId} {
      allow read:   if isAuth();
      allow create: if isAuth() && isAdmin();
      allow update: if isAuth() && isAdmin();
      allow delete: if isAuth() && isSuperAdmin();
    }

    // ── Audit Logs — append-only, no edit/delete ──────────────────────────────
    match /auditLogs/{logId} {
      allow read:   if isAuth() && isAdmin();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // ── Reports ───────────────────────────────────────────────────────────────
    match /reports/{rptId} {
      allow read:   if isAuth() && isAgent();
      allow create: if isAuth() && isAgent();
      allow update: if isAuth() && isAgent();
      allow delete: if isAuth() && isAdmin();
    }

    // ── SLA Policies ──────────────────────────────────────────────────────────
    match /slaPolicies/{slaId} {
      allow read:   if isAuth();
      allow write:  if isAuth() && isAdmin();
    }

    // ── Knowledge Base ────────────────────────────────────────────────────────
    match /knowledgeBase/{artId} {
      allow read:   if isAuth();
      allow create: if isAuth() && isAgent();
      allow update: if isAuth() && isAgent();
      allow delete: if isAuth() && isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:   if isAuth() && (isAdmin() || resource.data.userId == uid());
      allow create: if isAuth() && isAgent();
      allow update: if isAuth() && (isAdmin() || resource.data.userId == uid());
      allow delete: if isAuth() && isAdmin();
    }
  }
}
