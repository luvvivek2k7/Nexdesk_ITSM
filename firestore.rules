rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function getUserRole() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function isRole(role) { return isSignedIn() && getUserRole() == role; }
    function isAnyRole(roles) { return isSignedIn() && getUserRole() in roles; }
    function isSuperAdmin() { return isRole('super_admin'); }
    function isAdminOrAbove() { return isAnyRole(['super_admin', 'it_admin']); }
    function isAgentOrAbove() { return isAnyRole(['super_admin', 'it_admin', 'it_agent']); }
    function isManagerOrAbove() { return isAnyRole(['super_admin', 'it_admin', 'manager']); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdminOrAbove() || isManagerOrAbove();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isOwner(userId) || isAdminOrAbove();
      allow delete: if isSuperAdmin();
    }

    // Tickets
    match /tickets/{ticketId} {
      allow read: if isAgentOrAbove() || isManagerOrAbove()
                  || (isSignedIn() && resource.data.requesterId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.requesterId == request.auth.uid;
      allow update: if isAgentOrAbove() || isAdminOrAbove()
                    || (isSignedIn() && resource.data.requesterId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comments','updatedAt']));
      allow delete: if isAdminOrAbove();
    }

    // Assets (ITAM) — agents and above can manage
    match /assets/{assetId} {
      allow read: if isAgentOrAbove() || isManagerOrAbove();
      allow create: if isAgentOrAbove();
      allow update: if isAgentOrAbove();
      allow delete: if isAdminOrAbove();
    }

    // Workflows
    match /workflows/{wfId} {
      allow read: if isAgentOrAbove();
      allow write: if isAdminOrAbove();
    }

    // Knowledge
    match /knowledge/{articleId} {
      allow read: if isSignedIn();
      allow write: if isAgentOrAbove();
    }

    // SLA policies
    match /sla_policies/{policyId} {
      allow read: if isSignedIn();
      allow write: if isAdminOrAbove();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Meta (counters, stats)
    match /meta/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Audit logs (immutable)
    match /audit_logs/{logId} {
      allow read: if isAdminOrAbove();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
