rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Core auth helpers ─────────────────────────────────────────────────────
    function isAuth()    { return request.auth != null; }
    function uid()       { return request.auth.uid; }
    function isOwner(id) { return uid() == id; }

    // ── Safe profile read ─────────────────────────────────────────────────────
    // CRITICAL: me() can fail if the user doc doesn't exist yet (first login).
    // We wrap in exists() check to prevent permission cascades on new users.
    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(uid()));
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    // Safe role/org reads — return defaults if doc doesn't exist yet
    function myRole() {
      return userDocExists() ? me().role : 'anonymous';
    }
    function myOrg() {
      return userDocExists() ? me().orgId : '';
    }
    function isActive() {
      return userDocExists() ? (me().active == true) : false;
    }

    // ── Role helpers ──────────────────────────────────────────────────────────
    function isSuperAdmin()  { return myRole() == 'super_admin'; }
    function isOrgAdmin()    { return myRole() in ['super_admin', 'org_admin']; }
    function isAdmin()       { return myRole() in ['super_admin', 'org_admin', 'it_admin']; }
    function isAgent()       { return myRole() in ['super_admin', 'org_admin', 'it_admin', 'it_agent']; }
    function isManager()     { return myRole() in ['super_admin', 'org_admin', 'it_admin', 'manager']; }
    function isHR()          { return myRole() in ['super_admin', 'org_admin', 'it_admin', 'hr', 'manager']; }
    function isFSO()         { return myRole() in ['super_admin', 'org_admin', 'it_admin', 'field_engineer', 'manager']; }
    function isActiveUser()  { return isAuth() && isActive(); }

    // Org isolation
    function sameOrg(res) {
      return isSuperAdmin() || res.data.orgId == myOrg();
    }

    // ── Organizations ─────────────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read:   if isAuth() && (isSuperAdmin() || myOrg() == orgId);
      allow create: if isSuperAdmin();
      allow update: if isAuth() && (isSuperAdmin() || (isOrgAdmin() && myOrg() == orgId));
      allow delete: if isSuperAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // KEY FIX: New users logging in for the first time need to:
    //   1. Search for their placeholder doc by email (query on users collection)
    //   2. Create their real doc at their Firebase UID
    // Both operations must be allowed for ANY authenticated user.
    match /users/{userId} {
      // Any authenticated user can read:
      //   - Their OWN doc (by UID or placeholder)
      //   - Any user doc if they are an agent/admin (for dropdowns, assignment)
      allow read: if isAuth() && (
        isOwner(userId) ||
        isAgent()       ||
        isManager()     ||
        isHR()          ||
        // Allow reading placeholder docs by email search during first login
        // (Firestore collection queries are handled separately below)
        true  // All authenticated users can read user docs — role determines UI visibility
      );

      // First-login: any authenticated user can create their own UID doc
      // This covers the placeholder→real merge in AuthContext
      allow create: if isAuth() && (
        isOwner(userId) ||
        isAdmin()
      );

      // Update: own doc or admin
      allow update: if isAuth() && (
        isOwner(userId) ||
        isAdmin()
      );

      allow delete: if isAuth() && isOrgAdmin();
    }

    // ── Tickets ───────────────────────────────────────────────────────────────
    match /tickets/{ticketId} {
      allow read: if isActiveUser() && (
        isSuperAdmin() || isAgent() || isManager() ||
        resource.data.requesterId == uid() ||
        resource.data.assigneeId  == uid()
      );
      allow create: if isActiveUser();
      allow update: if isActiveUser() && (
        isAgent() || isManager() ||
        resource.data.requesterId == uid()
      );
      allow delete: if isActiveUser() && isSuperAdmin();
    }

    match /tickets/{ticketId}/comments/{commentId} {
      allow read:   if isActiveUser();
      allow create: if isActiveUser();
      allow update: if isActiveUser() && resource.data.authorId == uid();
      allow delete: if isActiveUser() && isAdmin();
    }

    // ── Assets (ITAM) ─────────────────────────────────────────────────────────
    match /assets/{assetId} {
      allow read:   if isActiveUser();
      allow create: if isActiveUser() && (isAgent() || isAdmin());
      allow update: if isActiveUser() && (isAgent() || isAdmin());
      allow delete: if isActiveUser() && isAdmin();
    }

    // ── Employees (HRMS) ──────────────────────────────────────────────────────
    match /employees/{empId} {
      allow read:   if isActiveUser();
      allow create: if isActiveUser() && isHR();
      allow update: if isActiveUser() && isHR();
      allow delete: if isActiveUser() && isOrgAdmin();
    }

    // ── Work Orders (FSO) ─────────────────────────────────────────────────────
    match /workOrders/{woId} {
      allow read:   if isActiveUser() && (
        isFSO() || isManager() || resource.data.assigneeId == uid()
      );
      allow create: if isActiveUser() && (isFSO() || isManager());
      allow update: if isActiveUser() && (
        isFSO() || isManager() || resource.data.assigneeId == uid()
      );
      allow delete: if isActiveUser() && isAdmin();
    }

    // ── Access Requests (IAM) ─────────────────────────────────────────────────
    match /accessRequests/{reqId} {
      allow read: if isActiveUser() && (
        isAdmin() || isManager() ||
        resource.data.requesterId == uid() ||
        resource.data.approverId  == uid()
      );
      allow create: if isActiveUser();
      allow update: if isActiveUser() && (
        isAdmin() || isManager() || resource.data.approverId == uid()
      );
      allow delete: if isActiveUser() && isAdmin();
    }

    // ── Visitors ──────────────────────────────────────────────────────────────
    match /visitors/{visId} {
      allow read:   if isActiveUser();
      allow create: if isActiveUser();
      allow update: if isActiveUser() && (isAgent() || isManager() || resource.data.hostId == uid());
      allow delete: if isActiveUser() && isAdmin();
    }

    // ── Assignment Groups ─────────────────────────────────────────────────────
    // All authenticated active users can read groups (needed for ticket assignment dropdowns)
    match /assignment_groups/{grpId} {
      allow read:   if isAuth();
      allow create: if isActiveUser() && isAdmin();
      allow update: if isActiveUser() && isAdmin();
      allow delete: if isActiveUser() && isOrgAdmin();
    }

    // ── Workflows ─────────────────────────────────────────────────────────────
    match /workflows/{wfId} {
      allow read:   if isActiveUser() && isAdmin();
      allow create: if isActiveUser() && isAdmin();
      allow update: if isActiveUser() && isAdmin();
      allow delete: if isActiveUser() && isOrgAdmin();
    }

    // ── Audit Logs — append-only ──────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read:   if isActiveUser() && isAdmin();
      allow create: if isActiveUser();
      allow update: if false;
      allow delete: if false;
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:   if isAuth() && (isAdmin() || resource.data.userId == uid());
      allow create: if isAuth();
      allow update: if isAuth() && (isAdmin() || resource.data.userId == uid());
      allow delete: if isAuth() && isAdmin();
    }

    // ── Custom Roles ──────────────────────────────────────────────────────────
    match /custom_roles/{roleId} {
      allow read:   if isActiveUser();
      allow create: if isActiveUser() && isOrgAdmin();
      allow update: if isActiveUser() && isOrgAdmin();
      allow delete: if isActiveUser() && isOrgAdmin();
    }

    // ── SLA Policies ──────────────────────────────────────────────────────────
    match /sla_policies/{polId} {
      allow read:   if isActiveUser();
      allow write:  if isActiveUser() && isAdmin();
    }

    // ── Knowledge Base ────────────────────────────────────────────────────────
    match /knowledge_base/{artId} {
      allow read:   if isActiveUser();
      allow create: if isActiveUser() && isAgent();
      allow update: if isActiveUser() && isAgent();
      allow delete: if isActiveUser() && isAdmin();
    }

    // ── Meta / counters ───────────────────────────────────────────────────────
    match /meta/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }

    // ── Reports ───────────────────────────────────────────────────────────────
    match /reports/{rptId} {
      allow read:   if isActiveUser() && isManager();
      allow create: if isActiveUser() && isAgent();
      allow update: if isActiveUser() && isAgent();
      allow delete: if isActiveUser() && isAdmin();
    }
  }
}
