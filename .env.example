# ─────────────────────────────────────────────────────────────────────────────
# NexDesk — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git — it's in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase (required) ───────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ── Claude AI API (Phase 2) ───────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
# Free $5 credit on signup
VITE_CLAUDE_API_KEY=sk-ant-your-key-here

# ── OpenAI (Phase 2 fallback) ─────────────────────────────────────────────────
# Get from: https://platform.openai.com → API Keys
# Free $5 credit on signup
VITE_OPENAI_API_KEY=sk-your-key-here

# ── Twilio (Phase 3) ──────────────────────────────────────────────────────────
# Get from: https://console.twilio.com
# Free $15 trial credit — no card needed
VITE_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_TWILIO_AUTH_TOKEN=your_auth_token_here
VITE_TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Google Maps (Phase 2 FSO) ─────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → Maps JavaScript API
# $200 free credit/month
VITE_GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# ── App config ────────────────────────────────────────────────────────────────
VITE_APP_NAME=NexDesk
VITE_APP_ENV=development
